# Phase 0 spike config. Copy to .env and fill in.
# .env is gitignored — never commit a real one.

# The target group's JID. Leave blank on first run; the READY log prints all
# your groups' JIDs, then paste the right one here.
WA_GROUP_JID=

# Set to 1 to post a text RSVP prompt into WA_GROUP_JID on startup.
# Members can REACT 👍/👎 to it or type YES/NO. Off by default (no re-run spam).
SEND_HELLO=0

# Set to 1 to post a NATIVE WhatsApp Poll (Yes/No) into WA_GROUP_JID on startup.
# Members tap an option; we listen for vote_update. Test this vs reactions.
SEND_POLL=0

# Only needed on a server with a system Chromium. Leave blank on a laptop.
CHROMIUM_PATH=

# ── bot.js (the real Phase 2 client) — drains the queue + forwards votes ──
# Where Django lives. Local end-to-end: same machine, no tunnel needed.
INDCRIC_BASE_URL=http://localhost:8000
# Must MATCH the values in the Django (root) .env.
BOT_INBOUND_TOKEN=
BOT_WEBHOOK_TOKEN=
# How often bot.js drains the outbound queue (ms).
POLL_INTERVAL_MS=20000
# Reuse the spike's linked session by default (no re-scan). Set a distinct id in prod.
WA_CLIENT_ID=indcric-spike
